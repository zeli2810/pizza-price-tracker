rules_version = '2';

// Pizza Price Tracker — Firestore security rules.
//
// The dashboard is a public, read-only view of pizza prices, so anyone may
// READ the price data. Nobody may WRITE from the client: all writes come from
// the GitHub Actions scraper, which uses the Firebase Admin SDK and bypasses
// these rules entirely (server-side service account).
service cloud.firestore {
  match /databases/{database}/documents {

    // Public, read-only collections consumed by the dashboard.
    match /price_history/{date} {
      allow read: if true;
      allow write: if false;
    }
    match /paisplus_offers/{date} {
      allow read: if true;
      allow write: if false;
    }
    match /wolt_offers/{date} {
      allow read: if true;
      allow write: if false;
    }
    match /marketing_sources/{id} {
      allow read: if true;
      // User-added sources from the dashboard (online feeds / offline references).
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 200
        && request.resource.data.kind in ['online', 'offline'];
      allow update, delete: if false;
    }
    match /marketing_ideas/{id} {
      allow read: if true;
      // Scraped ideas come from the Admin SDK (bypasses rules). From the browser,
      // allow ONLY manually-added ideas, with a validated shape; no edits/deletes.
      allow create: if request.resource.data.is_manual == true
        && request.resource.data.source_name == 'ידני'
        && request.resource.data.brand is string
        && request.resource.data.brand.size() > 0
        && request.resource.data.brand.size() < 200
        && request.resource.data.summary is string
        && request.resource.data.summary.size() < 5000;
      allow update, delete: if false;
    }
    match /branch_counts/{date} {
      allow read: if true;
      allow write: if false;
    }
    match /meta/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
